    <string name="dxwrapper_help_content"><![CDATA[
        <i><b>WineD3D</b></i> DirectX 1-11\'in OpenGL\'e çeviri katmanıdır.<br /><br />
        <i><b>DXVK</b></i> Direct3D 9-11\'in Vulkan\'a çeviri katmanıdır.<br /><br />
        <i><b>VKD3D</b></i> Direct3D 12 API\'sinin Vulkan\'a çeviri katmanıdır.<br /><br />
        <i><b>CNC DDraw</b></i> klasik oyunlarla daha iyi uyumluluk için DirectDraw uygulamasıdır.
    ]]></string>
    <string name="box86_64_env_var_help__dynarec_safeflags"><![CDATA[
        CALL/RET kodlarında bayrak (flag) yönetimi<br /><br />
        <b>0</b> : CALL/RET bayrağa hiç ihtiyaç duymuyormuş gibi davranır (daha hızlı, kararsız)<br />
        <b>1</b> : Çoğu RET bayrağa ihtiyaç duyar, çoğu CALLS duymaz<br />
        <b>2</b> : Tüm CALL/RET işlemleri bayrağa ihtiyaç duyar (daha yavaş)
    ]]></string>
    <string name="box86_64_env_var_help__dynarec_fastnan">x86 gibi -NAN üretimi</string>
    <string name="box86_64_env_var_help__dynarec_fastround">Kesin x86 yuvarlama üretimi</string>
    <string name="box86_64_env_var_help__dynarec_x87double">x87 emülasyonu için Float/Double kullanımı</string>
    <string name="box86_64_env_var_help__dynarec_bigblock"><![CDATA[
        Dynarec BigBlock yapısı<br /><br />
        <b>0</b> : Olabildiğince büyük blok oluşturmaya çalışma<br />
        <b>1</b> : Dynarec bloğunu olabildiğince büyük oluştur<br />
        <b>2</b> : Dynarec bloğunu daha büyük oluştur (bloklar örtüştüğünde devam et, ama sadece elf belleğindeki bloklar için)<br />
        <b>3</b> : Dynarec bloğunu daha büyük oluştur (tüm bellek türleri için örtüşmelerde devam et)
    ]]></string>
    <string name="box86_64_env_var_help__dynarec_strongmem"><![CDATA[
        Güçlü Bellek modelinin simülasyonu<br /><br />
        <b>0</b> : Özel bir şey deneme<br />
        <b>1</b> : Belleğe (bazı MOV işlemlerine) yazarken Bellek Bariyerini etkinleştir<br />
        <b>2</b> : Seçenek 1\'e ek olarak MOV kullanan her bellek yazımında Bellek Bariyeri kullan<br />
        <b>3</b> : Seçenek 2\'ye ek olarak bellekten okurken ve bazı SSE/SSE2 işlemlerinde Bellek Bariyeri kullan
    ]]></string>
    <string name="box86_64_env_var_help__dynarec_forward">Blok oluştururken izin verilen maksimum ileri (forward) değeri belirler</string>
    <string name="box86_64_env_var_help__dynarec_callret">CALL/RET işlemlerinin optimizasyonu</string>
    <string name="box86_64_env_var_help__dynarec_wait">Dynarec\'in FillBlock\'un hazır olmasını bekleyip beklemeyeceğini tanımlar</string>
    <string name="box86_64_env_var_help__avx"><![CDATA[
        AVX ve AVX2 uygulandı, ayrıca BMI1, BMI2, ADX, FMA, F16C ve RDRAND eklentileri!<br /><br />
        <b>0</b> : AVX uzantısını devre dışı bırak<br />
        <b>1</b> : AVX, BMI1, F16C ve VAES uzantılarını etkinleştir.<br />
        <b>2</b> : Seçenek 1\'e ek olarak AVX2, BMI2, FMA, ADX, VPCLMULQDQ ve RDRAND etkinleştir.<br />\
    ]]></string>
